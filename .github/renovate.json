{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>Omochice/personal-renovate-config#v1.15.0"
  ],
  "labels": [
    "dependencies"
  ],
  "reviewers": [
    "Omochice"
  ],
  "assignees": [
    "Omochice"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "addLabels": [
        "go"
      ]
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "semanticCommitType": "ci",
      "semanticCommitScope": "deps",
      "addLabels": [
        "github-actions"
      ]
    }
  ]
}
