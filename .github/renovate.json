{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>Omochice/personal-renovate-config#v1.15.0"
  ],
  "reviewers": [
    "Omochice"
  ],
  "assignees": [
    "Omochice"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "gomod"
      ],
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "semanticCommitType": "ci",
      "semanticCommitScope": "deps"
    }
  ]
}
